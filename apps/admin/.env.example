# Screen SaaS environment template
#
# How to use this file:
# 1. Copy it to `apps/admin/.env.local` for local work.
# 2. Add the same keys to Vercel or your production host for deploys.
# 3. Fill the sections from top to bottom.
# 4. After each section, run `npm run saas:check` from the repo root.
#
# Notes:
# - Variables prefixed with `NEXT_PUBLIC_` are exposed to the browser.
# - All other secrets must stay server-side.
# - Do not commit real production values.

# ---------------------------------------------------------------------------
# 1. App identity and customer-facing links
# ---------------------------------------------------------------------------

# APP_URL
# Primary base URL for canonical links, Stripe return URLs, sitemap entries,
# and marketing metadata.
APP_URL=http://localhost:3000

# STATUS_PAGE_URL
# Public uptime or incident page linked from the footer and legal pages.
STATUS_PAGE_URL=https://status.example.com

# SUPPORT_EMAIL
# Main support inbox shown in the footer, billing UI, and contact flows.
SUPPORT_EMAIL=support@example.com

# SALES_EMAIL
# Inbox for sales or demo requests from the public contact page.
SALES_EMAIL=sales@example.com

# LEGAL_COMPANY_NAME
# Exact legal entity name that appears in Terms, Privacy, DPA, and footer copy.
LEGAL_COMPANY_NAME=Screen Labs LLC

# LEGAL_COMPANY_ADDRESS
# Full postal mailing address for the legal entity above.
LEGAL_COMPANY_ADDRESS=123 Market Street, New York, NY 10001

# LEGAL_EMAIL
# Inbox for privacy, DPA, compliance, or other legal requests.
LEGAL_EMAIL=legal@example.com

# ---------------------------------------------------------------------------
# 2. Clerk authentication
# ---------------------------------------------------------------------------

# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
# Browser-safe Clerk publishable key from Clerk Dashboard -> API Keys.
# Example format: pk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# CLERK_SECRET_KEY
# Server-side Clerk secret key from Clerk Dashboard -> API Keys.
# Example format: sk_test_...
CLERK_SECRET_KEY=sk_test_replace_me

# CLERK_WEBHOOK_SIGNING_SECRET
# Signing secret from the Clerk webhook configured to POST to:
# https://your-app.example.com/api/webhooks/clerk
# Example format: whsec_...
CLERK_WEBHOOK_SIGNING_SECRET=whsec_replace_me

# ---------------------------------------------------------------------------
# 3. Convex backend
# ---------------------------------------------------------------------------

# NEXT_PUBLIC_CONVEX_URL
# Public HTTPS URL for the Convex deployment the Next.js app should call.
# Copy this from `npx convex status` or the Convex dashboard.
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# CONVEX_DEPLOYMENT
# Exact Convex deployment selector used by the CLI and backend tooling.
# Copy this from `npx convex status`.
CONVEX_DEPLOYMENT=prod:your-project

# CLERK_JWT_ISSUER_DOMAIN
# Clerk issuer URL used by Convex auth validation.
# Copy the `iss` value from a Clerk token or the issuer shown in Clerk JWT
# settings so it matches your Clerk instance exactly.
CLERK_JWT_ISSUER_DOMAIN=https://issuer.example.com

# ---------------------------------------------------------------------------
# 4. File uploads
# ---------------------------------------------------------------------------

# UPLOADTHING_TOKEN
# UploadThing app token used by the media upload routes.
# Get this from UploadThing Dashboard -> API keys.
UPLOADTHING_TOKEN=ut_replace_me

# ---------------------------------------------------------------------------
# 5. Email delivery
# ---------------------------------------------------------------------------

# RESEND_API_KEY
# Resend API key used by /api/contact to send inbound sales/support messages.
# Get this from Resend Dashboard -> API Keys.
RESEND_API_KEY=re_replace_me

# ---------------------------------------------------------------------------
# 6. Stripe billing
# ---------------------------------------------------------------------------

# STRIPE_SECRET_KEY
# Server-side Stripe secret key used for checkout, portal sessions, and price
# lookup. Get it from Stripe Dashboard -> Developers -> API keys.
STRIPE_SECRET_KEY=sk_test_replace_me

# STRIPE_WEBHOOK_SECRET
# Stripe webhook signing secret for the endpoint that POSTs to:
# https://your-app.example.com/api/webhooks/stripe
# Get it from Stripe Dashboard -> Developers -> Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# STRIPE_PRICE_STARTER_MONTH
# Stripe Price ID for the Starter monthly base subscription.
STRIPE_PRICE_STARTER_MONTH=price_replace_me

# STRIPE_PRICE_STARTER_YEAR
# Stripe Price ID for the Starter annual base subscription.
STRIPE_PRICE_STARTER_YEAR=price_replace_me

# STRIPE_PRICE_GROWTH_MONTH
# Stripe Price ID for the Growth monthly base subscription.
STRIPE_PRICE_GROWTH_MONTH=price_replace_me

# STRIPE_PRICE_GROWTH_YEAR
# Stripe Price ID for the Growth annual base subscription.
STRIPE_PRICE_GROWTH_YEAR=price_replace_me

# STRIPE_PRICE_SCALE_MONTH
# Stripe Price ID for the Scale monthly base subscription.
STRIPE_PRICE_SCALE_MONTH=price_replace_me

# STRIPE_PRICE_SCALE_YEAR
# Stripe Price ID for the Scale annual base subscription.
STRIPE_PRICE_SCALE_YEAR=price_replace_me

# STRIPE_OVERAGE_STARTER_MONTH
# Stripe Price ID for Starter monthly per-screen overage charges.
STRIPE_OVERAGE_STARTER_MONTH=price_replace_me

# STRIPE_OVERAGE_STARTER_YEAR
# Stripe Price ID for Starter annual per-screen overage charges.
STRIPE_OVERAGE_STARTER_YEAR=price_replace_me

# STRIPE_OVERAGE_GROWTH_MONTH
# Stripe Price ID for Growth monthly per-screen overage charges.
STRIPE_OVERAGE_GROWTH_MONTH=price_replace_me

# STRIPE_OVERAGE_GROWTH_YEAR
# Stripe Price ID for Growth annual per-screen overage charges.
STRIPE_OVERAGE_GROWTH_YEAR=price_replace_me

# STRIPE_OVERAGE_SCALE_MONTH
# Stripe Price ID for Scale monthly per-screen overage charges.
STRIPE_OVERAGE_SCALE_MONTH=price_replace_me

# STRIPE_OVERAGE_SCALE_YEAR
# Stripe Price ID for Scale annual per-screen overage charges.
STRIPE_OVERAGE_SCALE_YEAR=price_replace_me

# ---------------------------------------------------------------------------
# 7. Sentry error monitoring
# ---------------------------------------------------------------------------

# SENTRY_DSN
# Server-side Sentry DSN used by Next.js server runtime instrumentation.
SENTRY_DSN=https://server-key@example.ingest.sentry.io/1234567

# NEXT_PUBLIC_SENTRY_DSN
# Browser-safe Sentry DSN used by the client runtime.
NEXT_PUBLIC_SENTRY_DSN=https://public-key@example.ingest.sentry.io/1234567

# SENTRY_AUTH_TOKEN
# Optional but recommended. Needed to upload sourcemaps during builds.
# Get it from Sentry -> Settings -> Auth Tokens.
SENTRY_AUTH_TOKEN=sntrys_replace_me

# SENTRY_ORG
# Optional but recommended. Your Sentry organization slug.
SENTRY_ORG=your-sentry-org

# SENTRY_PROJECT
# Optional but recommended. Your Sentry project slug for this app.
SENTRY_PROJECT=screen-admin

# ---------------------------------------------------------------------------
# 8. Runtime mode
# ---------------------------------------------------------------------------

# SHOWROOM_MOCK_MODE
# Local demo switch. Keep this `true` only when you want mock data with no live
# backend. Any real SaaS environment should set this to `false`.
SHOWROOM_MOCK_MODE=true
