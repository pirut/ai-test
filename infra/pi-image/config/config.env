SHOWROOM_API_BASE_URL=https://screen.jrbussard.com
SHOWROOM_STORAGE_ROOT=/var/lib/showroom/cache
SHOWROOM_STATE_ROOT=/var/lib/showroom/state
SHOWROOM_PLAYER_DIST=/opt/showroom/player
SHOWROOM_LISTEN_ADDR=127.0.0.1:4173
SHOWROOM_POLL_INTERVAL=15s
SHOWROOM_HEARTBEAT_INTERVAL=30s
SHOWROOM_SCREENSHOT_INTERVAL=15m
SHOWROOM_SCREENSHOT_COMMAND=DISPLAY=:0 XAUTHORITY=/home/pi/.Xauthority scrot -q 85 -o /tmp/showroom-screenshot.jpg
SHOWROOM_YTDLP_BINARY=yt-dlp
SHOWROOM_YTDLP_FORMAT='best[protocol=https][vcodec!=none][acodec!=none][height<=2160]/best[ext=mp4][vcodec!=none][acodec!=none][height<=2160]/bestvideo*[protocol=https][height<=2160]+bestaudio[protocol=https]/bestvideo*[height<=2160]+bestaudio/best[height<=2160]/best'
SHOWROOM_YTDLP_EXTRACTOR_ARGS='youtube:player_client=tv,mweb,ios,android;formats=incomplete'
SHOWROOM_YTDLP_COOKIE_FILE=/etc/showroom-agent/youtube.cookies.txt
SHOWROOM_RESTART_PLAYER_COMMAND=systemctl restart showroom-kiosk.service
SHOWROOM_RESTART_AGENT_COMMAND=systemctl restart showroom-agent.service
SHOWROOM_REBOOT_COMMAND=shutdown -r now
SHOWROOM_BLANK_COMMAND=vcgencmd display_power 0
SHOWROOM_UNBLANK_COMMAND=vcgencmd display_power 1
