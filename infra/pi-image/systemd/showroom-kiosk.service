[Unit]
Description=Showroom Chromium kiosk
After=showroom-agent.service systemd-user-sessions.service
Wants=showroom-agent.service
Conflicts=getty@tty1.service

[Service]
ExecStart=/usr/local/bin/showroom-start-kiosk
Restart=always
RestartSec=5
User=pi
Environment=DISPLAY=:0
TTYPath=/dev/tty1
StandardInput=tty
StandardOutput=journal
StandardError=journal
TTYReset=yes
TTYVHangup=yes
TTYVTDisallocate=yes

[Install]
WantedBy=multi-user.target
