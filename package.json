{
  "name": "showroom-signage",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "convex:codegen": "npx convex codegen",
    "convex:dev": "npx convex dev",
    "dev": "npm run dev --workspace @showroom/admin",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present && npm run typecheck:convex",
    "typecheck:convex": "tsc --noEmit -p convex/tsconfig.json",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "convex": "^1.26.2",
    "shadcn": "^4.0.6",
    "typescript": "^5.8.2"
  }
}
